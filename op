# ─── Main ──────────────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift || true

  # Only load config for commands that need API access
  case "$cmd" in
    help|--help|-h)
      show_help
      exit 0
      ;;
    version|--version|-v)
      echo "op v${VERSION}"
      exit 0
      ;;
    projects)
      load_config
      cmd_projects "$@"
      ;;
    workpackages|wp)
      load_config
      cmd_workpackages "$@"
      ;;
    members|m)
      load_config
      cmd_members "$@"
      ;;
    *)
      echo "Unknown command: $cmd"
      show_help
      exit 1
      ;;
  esac
}

main "$@"
